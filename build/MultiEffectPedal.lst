  51:MultiEffectPedal.cpp **** constexpr float DELAY_FEEDBACK = 0.45f;
  52:MultiEffectPedal.cpp **** constexpr float DELAY_WET = 0.45f;
  53:MultiEffectPedal.cpp **** 
  54:MultiEffectPedal.cpp **** //Flanger
  55:MultiEffectPedal.cpp **** constexpr float FLANGER_DELAY_MS = 2.0f;
  56:MultiEffectPedal.cpp **** constexpr float FLANGER_FEEDBACK = 0.45f;
