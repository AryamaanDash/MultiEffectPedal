  42:MultiEffectPedal.cpp **** constexpr float DISTORTION_LEVEL = 0.85f;
  43:MultiEffectPedal.cpp **** 
  44:MultiEffectPedal.cpp **** //Reverb
  45:MultiEffectPedal.cpp **** constexpr float REVERB_FEEDBACK = 0.86f;
  46:MultiEffectPedal.cpp **** constexpr float REVERB_LP_FREQ = 10000.0f;
  47:MultiEffectPedal.cpp **** constexpr float REVERB_WET = 0.40f;
  48:MultiEffectPedal.cpp **** 
