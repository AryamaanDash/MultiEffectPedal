  58:MultiEffectPedal.cpp **** constexpr float FLANGER_RATE_HZ = 0.25f;
  59:MultiEffectPedal.cpp **** constexpr float FLANGER_WET = 0.75f;
  60:MultiEffectPedal.cpp **** 
  61:MultiEffectPedal.cpp **** //Utility Functions
  62:MultiEffectPedal.cpp **** 
  63:MultiEffectPedal.cpp **** float ClampAudio(float sample){
  64:MultiEffectPedal.cpp **** 	if(sample > 1.0f){
  65:MultiEffectPedal.cpp **** 		return 1.0f;
  66:MultiEffectPedal.cpp **** 	}
  67:MultiEffectPedal.cpp **** 
  68:MultiEffectPedal.cpp **** 	if(sample < -1.0f){
  69:MultiEffectPedal.cpp **** 		return -1.0f;
  70:MultiEffectPedal.cpp **** 	}
  71:MultiEffectPedal.cpp **** 
  72:MultiEffectPedal.cpp **** 	return sample;
  73:MultiEffectPedal.cpp **** }
  74:MultiEffectPedal.cpp **** 
  75:MultiEffectPedal.cpp **** float DryWet(float dry, float wet, float wet_amount){
  76:MultiEffectPedal.cpp **** 	return dry * (1.0f - wet_amount) + wet * wet_amount;
  77:MultiEffectPedal.cpp **** }
